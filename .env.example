# Contact form email delivery (Resend — https://resend.com)
# Without these, the contact form gracefully falls back to a mailto: link.

# Your Resend API key (required to actually send mail).
RESEND_API_KEY=

# Where messages are delivered. Defaults to the email in data/portfolio.ts.
CONTACT_TO_EMAIL=

# Verified sender on your Resend domain. Defaults to Resend's sandbox sender.
# CONTACT_FROM_EMAIL="Hunter System <hello@yourdomain.com>"
